<?php

/**
 * Implements hook_cron().
 */
function content_janitor_cron() {
  $rules = \Drupal::entityTypeManager()->getStorage('content_janitor_rule')->loadMultiple();
  
  if (empty($rules)) {
    return;
  }

  foreach ($rules as $rule) {
    $content_type = $rule->target_content_type;
    $field_name = $rule->target_date_field;
    $threshold = $rule->age_threshold;
    $limit = $rule->batch_limit ?: 50;

    $threshold_time = strtotime($threshold);

    if (!$threshold_time) {
      \Drupal::logger('content_janitor')->error('ERROR: Invalid age threshold format "@threshold" on Rule "@rule".', [
        '@threshold' => $threshold,
        '@rule' => $rule->label(),
      ]);
      continue;
    }

    $human_readable_target = date('Y-m-d H:i:s', $threshold_time);

    try {
      $query = \Drupal::entityQuery('node')
        ->condition('type', $content_type)
        ->condition('status', 1)
        ->range(0, $limit)
        ->accessCheck(FALSE); 
      
      if (in_array($field_name, ['created', 'changed'])) {
        $query->condition($field_name, $threshold_time, '<');
      } else {
        $query->condition($field_name, date('Y-m-d\TH:i:s', $threshold_time), '<');
      }
      
      $nids = $query->execute();

      if (!empty($nids)) {
        $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
        $count = 0;
        $unpublished_details = [];
        
        foreach ($nodes as $node) {
          $node->setUnpublished();
          $node->setNewRevision(TRUE);
          $node->revision_log = "Content Janitor Rule ({$rule->label()}): $field_name is older than $threshold.";
          $node->setRevisionUserId(1); 
          $node->save();
          
          $unpublished_details[] = $node->label() . ' (ID: ' . $node->id() . ')';
          $count++;
        }
        
        $details_string = implode(', ', $unpublished_details);
        
        \Drupal::logger('content_janitor')->notice('SUCCESS: Rule "@rule" unpublished @count nodes. <br><strong>Nodes:</strong> @details', [
          '@rule' => $rule->label(),
          '@count' => $count,
          '@details' => $details_string,
        ]);
      } else {
        // Upgraded from debug() to notice() so it is always visible in the UI.
        \Drupal::logger('content_janitor')->notice('SKIPPED: Rule "@rule" found 0 nodes. (Looked for @field_name older than @date)', [
          '@rule' => $rule->label(),
          '@field_name' => $field_name,
          '@date' => $human_readable_target,
        ]);
      }
    } catch (\Throwable $e) {
      // Upgraded to \Throwable to catch modern PHP 8 TypeErrors and Fatal Errors.
      \Drupal::logger('content_janitor')->error('ERROR on Rule "@rule": @message', [
        '@rule' => $rule->label(),
        '@message' => $e->getMessage(),
      ]);
    }
  }
}